{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "pip install -r requirements.txt && python main.py",
    "nixpacksConfig": {
      "phases": {
        "setup": {
          "nixPkgs": ["ffmpeg"]
        }
      }
    }
  }
}
